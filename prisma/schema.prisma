generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // For migrations (bypasses Supabase pooler)
}


model ReporteEmergencia {
  id                String   @id @default(cuid())
  tipoReporte       String   @map("tipo_reporte")
  nombreCompleto    String   @map("nombre_completo")
  descripcionFisica String?  @map("descripcion_fisica")
  ubicacionExacta   String   @map("ubicacion_exacta")
  estado            String
  contacto          String
  notaAdicional     String?  @map("nota_adicional")
  urgenciaAi        Int?     @map("urgencia_ai")
  prioridadDesc     String?  @map("prioridad_desc")
  fechaRegistro     DateTime @default(now()) @map("fecha_registro")

  @@map("reportes_emergencia")
}