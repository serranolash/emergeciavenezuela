generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL") // Necesario si usas Supabase con pooling (ej. Neon o Supabase nativo)
}

model ReporteEmergencia {
  id                String   @id @default(cuid())
  tipoReporte       String   @default("Conocido")       // Conocido / Sin Identificar
  nombreCompleto    String?                               // null para desconocidos
  descripcionFisica String?                               // descripción física del desconocido
  ubicacionExacta   String
  estado            String   @default("Desaparecido")     // A salvo / Herido / Desaparecido / En tránsito
  contacto          String
  notaAdicional     String?
  urgenciaAi        Int?
  prioridadDesc     String?
  fechaRegistro     DateTime @default(now())
}