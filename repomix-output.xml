   234→        localStorage.setItem("pendingReports", JSON.stringify(pending));
   235→        toast({
   236→          title: "Guardado offline",
   237→          description: "Se enviará al recuperar conexión",
   238→          variant: "default",
   239→        });
   240→      } else {
   241→        const res = await fetch("/api/reportes", {
   242→          method: "POST",
   243→          headers: { "Content-Type": "application/json" },
   244→          body: JSON.stringify(payload),
   245→        });
   246→        const data = await res.json();
   247→        if (!res.ok) throw new Error(data.error || "Error al enviar reporte");
   248→        toast({ title: "Reporte enviado", description: "La IA está analizando la urgencia..." });
   249→      }
