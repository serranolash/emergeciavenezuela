   223→      ubicacion_exacta: formData.ubicacion_exacta.trim(),
   224→      estado: formData.estado,
   225→      contacto: formData.contacto.trim(),
   226→      nota_adicional: formData.nota_adicional.trim() || undefined,
   227→    };
   228→
   229→    try {
   230→      if (!navigator.onLine) {
