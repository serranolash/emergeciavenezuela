   251→      // Reset form and close
   252→      setFormData({ nombre_completo: "", ubicacion_exacta: "", estado: "", contacto: "", nota_adicional: "" });
   253→      setFormErrors({});
   254→      setDialogOpen(false);
   255→      fetchReportes();
