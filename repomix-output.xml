   203→  // Form validation
   204→  function validateForm(): boolean {
   205→    const errors: Record<string, string> = {};
   206→    if (!formData.nombre_completo.trim()) errors.nombre_completo = "Nombre completo requerido";
   207→    if (!formData.ubicacion_exacta.trim()) errors.ubicacion_exacta = "Ubicación requerida";
   208→    if (!formData.estado) errors.estado = "Seleccione un estado";
   209→    if (!formData.contacto.trim()) errors.contacto = "Contacto requerido";
   210→    setFormErrors(errors);
   211→    return Object.keys(errors).length === 0;
   212→  }
