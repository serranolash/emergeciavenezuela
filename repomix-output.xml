   116→    try {
   117→      setLoading(true);
   118→      const url = query ? `/api/reportes?q=${encodeURIComponent(query)}` : "/api/reportes";
   119→      const res = await fetch(url);
   120→      if (!res.ok) throw new Error("Error al cargar reportes");
   121→      const data = await res.json();
   122→      setReportes(data.reportes);
   123→    } catch {
   124→      toast({ title: "Error", description: "No se pudieron cargar los reportes", variant: "destructive" });
   125→    } finally {
   126→      setLoading(false);
   127→    }
   128→  }, [toast]);
   129→
   130→  useEffect(() => {
   131→    fetchReportes();
   132→  }, [fetchReportes]);
   133→
   134→  // Debounced search
   135→  useEffect(() => {
   136→    if (searchTimeout.current) clearTimeout(searchTimeout.current);
   137→    searchTimeout.current = setTimeout(() => {
   138→      if (searchQuery.trim().length === 0) {
   139→        setFilteredReportes(reportes);
   140→      } else {
   141→        const q = searchQuery.toLowerCase();
   142→        const filtered = reportes.filter(
   143→          (r) =>
   144→            r.nombreCompleto.toLowerCase().includes(q) ||
   145→            r.ubicacionExacta.toLowerCase().includes(q)
   146→        );
   147→        setFilteredReportes(filtered);
   148→      }
   149→    }, 250);
   150→    return () => {
   151→      if (searchTimeout.current) clearTimeout(searchTimeout.current);
   152→    };
   153→  }, [searchQuery, reportes]);
   154→
   155→  // Stats
   156→  useEffect(() => {
   157→    setStats({
   158→      total: reportes.length,
   159→      salvo: reportes.filter((r) => r.estado === "A salvo").length,
   160→      herido: reportes.filter((r) => r.estado === "Herido").length,
   161→      desaparecido: reportes.filter((r) => r.estado === "Desaparecido").length,
   162→    });
   163→  }, [reportes]);
   164→
   165→  // Online/offline detection
   166→  useEffect(() => {
   167→    const handleOnline = () => {
   168→      setIsOnline(true);
   169→      // Sync pending reports
   170→      const pending = localStorage.getItem("pendingReports");
   171→      if (pending) {
   172→        try {
   173→          const reports = JSON.parse(pending) as Array<Record<string, unknown>>;
   174→          reports.forEach(async (report) => {
   175→            try {
   176→              await fetch("/api/reportes", {
   177→                method: "POST",
